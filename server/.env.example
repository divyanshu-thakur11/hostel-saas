# ─────────────────────────────────────────────────────────────
#  Hostel SaaS Platform — Environment Configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/hostel_saas

# Server port
PORT=5000

# JWT Secret — MUST be a long random string in production
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# Environment
NODE_ENV=development

# Super Admin credentials (used only for first-time bootstrap)
# After first login you MUST change the password
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin123

# Allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Google Sheets (optional)
GOOGLE_SHEET_ID=your_sheet_id_here
